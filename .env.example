# Copy to .env and replace placeholder values.
# After copying: chmod 600 .env

# ── NVD API ────────────────────────────────────────────────────────────────
# Request a free key at https://nvd.nist.gov/developers/request-an-api-key
# Without one, the API rate-limit drops from 50/30s to 5/30s.
NVD_API_KEY=replace-with-your-nvd-api-key

# ── Postgres: DB owner (runs migrations, owns tables) ──────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nvd
POSTGRES_USER=nvd_owner
POSTGRES_PASSWORD=replace-with-strong-password

# ── Postgres: least-priv role used by the n8n workflow ─────────────────────
POSTGRES_APP_USER=nvd_app
POSTGRES_APP_PASSWORD=replace-with-strong-password

# ── n8n ────────────────────────────────────────────────────────────────────
# 32-byte hex; encrypts credentials stored inside n8n. Rotation = re-enter all creds.
N8N_ENCRYPTION_KEY=replace-with-64-hex-chars
N8N_HOST=127.0.0.1
N8N_PORT=5678
GENERIC_TIMEZONE=UTC

# NOTE: n8n 2.x deprecated N8N_BASIC_AUTH_*. You'll create an owner account
# on first visit to http://127.0.0.1:5678 — keep those credentials safe.

# ── Suggested generators (for reference) ───────────────────────────────────
# openssl rand -base64 32 | tr -d '/+=' | head -c 32   # passwords
# openssl rand -hex 32                                 # N8N_ENCRYPTION_KEY
